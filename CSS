/* The Zoom Button style */
.zoom-btn-icon {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(255, 255, 255, 0.8);
    border: none;
    border-radius: 50%;
    width: 35px;
    height: 35px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    z-index: 5;
    transition: 0.3s;
}

.zoom-btn-icon:hover {
    background: white;
    transform: scale(1.1);
}

/* Class to trigger when button is clicked */
.is-zoomed {
    transform: scale(1.5);
}