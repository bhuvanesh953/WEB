/* 1. The Container (The Window) */
.img-container {
    width: 100%;
    height: 250px;      /* Fixed height for all bike images */
    overflow: hidden;   /* This is CRITICAL for the zoom to stay inside */
    border-radius: 10px 10px 0 0; /* Rounds top corners only */
}

